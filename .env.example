# Neon Postgres connection strings
# Copy this file to .env.local and fill in real values from your Neon dashboard.
# .env.local is gitignored and stays out of source control.

# Pooled connection — used by app at runtime (serverless functions, server components).
# Hostname contains "-pooler".
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Direct connection — used by drizzle-kit for migrations only.
# Same as pooled but without "-pooler" in hostname.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# Auth - single shared password gating the whole app.
# AUTH_PASSWORD_HASH: bcrypt hash of your chosen password. Generate locally with:
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 10))" "your-password-here"
# AUTH_SESSION_SECRET: 32-byte random string for signing the session JWT. Generate with:
#   openssl rand -base64 32
# IMPORTANT: escape every $ in AUTH_PASSWORD_HASH with a backslash (\$).
# Next.js uses dotenv-expand which expands $VAR refs regardless of quoting
# (single or double), which mangles bcrypt hashes that contain $ chars.
# Example: \$2b\$10\$abc...   (no quotes around the value)
AUTH_PASSWORD_HASH=REPLACE_WITH_BCRYPT_HASH_WITH_DOLLARS_ESCAPED
AUTH_SESSION_SECRET="REPLACE_WITH_RANDOM_32_BYTE_BASE64"
